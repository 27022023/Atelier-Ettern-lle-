            background: radial-gradient(circle at top left, #ffffff, #fbefff, #f6e2ff);
            border: 1px solid rgba(255,255,255,0.9);
            border-radius: 18px;
            padding: 10px 12px;
            text-align: center;
            color: #3b233f;
            font-size: 0.9rem;
            cursor: pointer;
            transition: 0.2s ease;
            box-shadow:
