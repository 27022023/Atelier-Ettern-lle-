        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            min-height: 100vh;
            width: 100vw;
            background: radial-gradient(circle at top left, #ffe6ff, #f7d0ff, #f8c0e5, #f3b4ff);
